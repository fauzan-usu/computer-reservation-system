# CRS - Git Ignore

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Dependencies
node_modules/
vendor/

# Environment files
.env
.env.local
.env.*.local

# Log files
*.log
logs/

# Cache
*.cache
cache/

# Uploads (keep folder but not files)
assets/images/*
!assets/images/.gitkeep

# Database backups
*.sql.gz
*.sql.zip

# Temporary files
tmp/
temp/
*.tmp

# Build output
dist/
build/
